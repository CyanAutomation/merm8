# Merm8 API Server Configuration
# Copy this file to .env and set values according to your deployment environment

# MERM8_API_URL - Optional. Sets the server URL in the OpenAPI specification.
# This tells API clients (e.g., Swagger UI, SDKs) the actual server endpoint to call.
#
# When unset (not recommended for production):
#   - Local development: defaults to http://localhost:8080
#   - Production: defaults to https://api.example.com (placeholder - MUST be overridden)
#
# Recommended values by environment:
#   - Local development:        http://localhost:8080
#   - Docker Compose:           http://localhost:8080
#   - Docker Compose (remote):  http://<your-machine-ip>:8080
#   - Kubernetes:               https://api.<your-domain>.com
#   - Cloud Run (production):   https://api.<your-domain>.com
#
# Format: scheme://host[:port]
# Examples:
#   MERM8_API_URL=http://localhost:8080
#   MERM8_API_URL=https://api.example.com
#   MERM8_API_URL=https://merm8.mycompany.io:443
#
# This variable is used in:
#   - OpenAPI spec generation (internal/api/openapi.go)
#   - Swagger UI /docs endpoint (shows correct server URL)
#   - API client SDKs and integrations
#
MERM8_API_URL=http://localhost:8080

# Optional: Parser script location (usually not needed to change)
# PARSER_SCRIPT=/app/parser-node/parse.mjs

# Optional: Server port (usually not needed to change)
# PORT=8080

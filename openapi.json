{
  "components": {
    "schemas": {
      "AnalyzeRequest": {
        "properties": {
          "code": {
            "description": "Mermaid diagram code to analyze. Total request body must be 1 MiB or smaller. Supports suppression comments like `%% merm8-disable max-fanout` and `%% merm8-disable all`.",
            "example": "graph TD\n  A[Start] --\u003e B[Process]\n  B --\u003e C[End]",
            "type": "string"
          },
          "config": {
            "$ref": "#/components/schemas/RuleConfigSchema",
            "description": "Optional lint rule configuration. Supports both flat and nested formats:",
            "example": {
              "max-fanout": {
                "enabled": true,
                "limit": 3,
                "severity": "error",
                "suppression_selectors": [
                  "node:A"
                ]
              },
              "no-disconnected-nodes": {
                "enabled": false,
                "severity": "info"
              }
            }
          }
        },
        "required": [
          "code"
        ],
        "type": "object"
      },
      "AnalyzeResponse": {
        "properties": {
          "diagram_type": {
            "description": "Normalized Mermaid diagram type (flowchart, sequence, class, er, state, unknown).",
            "enum": [
              "flowchart",
              "sequence",
              "class",
              "er",
              "state",
              "unknown"
            ],
            "example": "flowchart",
            "type": "string"
          },
          "issues": {
            "description": "Lint rule violations found in the diagram",
            "items": {
              "$ref": "#/components/schemas/Issue"
            },
            "type": "array"
          },
          "lint_supported": {
            "description": "Whether lint rules are currently implemented for the parsed diagram type.",
            "type": "boolean"
          },
          "metrics": {
            "$ref": "#/components/schemas/Metrics",
            "description": "Aggregate statistics about the diagram. Present if valid.",
            "nullable": true
          },
          "syntax_error": {
            "$ref": "#/components/schemas/SyntaxError",
            "description": "Syntax error details if `valid` is false. Null if valid.",
            "nullable": true
          },
          "valid": {
            "description": "Whether the Mermaid code is syntactically valid",
            "type": "boolean"
          }
        },
        "required": [
          "valid",
          "lint_supported",
          "issues"
        ],
        "type": "object"
      },
      "ErrorDetail": {
        "properties": {
          "code": {
            "description": "Machine-readable error code",
            "example": "invalid_json",
            "type": "string"
          },
          "message": {
            "description": "Human-readable error message",
            "example": "invalid JSON body",
            "type": "string"
          },
          "path": {
            "description": "JSON path to the invalid config field when config validation fails",
            "example": "config.rules.max-fanout.limit",
            "type": "string"
          },
          "supported": {
            "description": "Supported values for unknown rule/option errors",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          },
          "issues": {
            "description": "Always empty for API-level errors",
            "items": {
              "$ref": "#/components/schemas/Issue"
            },
            "type": "array"
          },
          "valid": {
            "description": "Always false for non-200 responses",
            "type": "boolean"
          }
        },
        "required": [
          "valid",
          "issues",
          "error"
        ],
        "type": "object"
      },
      "Issue": {
        "properties": {
          "column": {
            "description": "0-based column number where issue is located when known. Omitted when unknown.",
            "example": 2,
            "nullable": true,
            "type": "integer"
          },
          "line": {
            "description": "1-based line number where issue is located when known. Omitted when unknown.",
            "example": 5,
            "nullable": true,
            "type": "integer"
          },
          "message": {
            "description": "Human-readable description of the issue",
            "example": "Node 'isolated' is not connected to the graph",
            "type": "string"
          },
          "rule_id": {
            "description": "Identifier of the lint rule that triggered",
            "example": "no-disconnected-nodes",
            "type": "string"
          },
          "severity": {
            "description": "Severity level of the issue",
            "enum": [
              "error",
              "warning",
              "info"
            ],
            "type": "string"
          }
        },
        "required": [
          "rule_id",
          "severity",
          "message"
        ],
        "type": "object"
      },
      "IssueCounts": {
        "properties": {
          "by_rule": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object"
          },
          "by_severity": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object"
          }
        },
        "required": [
          "by_severity",
          "by_rule"
        ],
        "type": "object"
      },
      "Metrics": {
        "properties": {
          "diagram_type": {
            "description": "Diagram type copied from parsed metadata",
            "enum": [
              "flowchart",
              "sequence",
              "class",
              "er",
              "state",
              "unknown"
            ],
            "example": "flowchart",
            "type": "string"
          },
          "direction": {
            "description": "Diagram direction when provided by parser",
            "example": "TD",
            "type": "string"
          },
          "disconnected_node_count": {
            "description": "Number of nodes with neither incoming nor outgoing edges",
            "example": 1,
            "type": "integer"
          },
          "duplicate_node_count": {
            "description": "Number of duplicate node declarations beyond first occurrences",
            "example": 0,
            "type": "integer"
          },
          "edge_count": {
            "description": "Total number of edges (connections) in the diagram",
            "example": 4,
            "type": "integer"
          },
          "issue_counts": {
            "$ref": "#/components/schemas/IssueCounts",
            "description": "Issue count aggregations by severity and rule ID"
          },
          "max_fanin": {
            "description": "Maximum number of incoming edges to any single node",
            "example": 3,
            "type": "integer"
          },
          "max_fanout": {
            "description": "Maximum number of outgoing edges from any single node",
            "example": 2,
            "type": "integer"
          },
          "node_count": {
            "description": "Total number of nodes in the diagram",
            "example": 5,
            "type": "integer"
          }
        },
        "required": [
          "node_count",
          "edge_count",
          "disconnected_node_count",
          "duplicate_node_count",
          "max_fanin",
          "max_fanout",
          "diagram_type"
        ],
        "type": "object"
      },
      "RuleConfigSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "oneOf": [
          {
            "additionalProperties": false,
            "properties": {
              "max-fanout": {
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "description": "Enable or disable this rule.",
                    "type": "boolean"
                  },
                  "limit": {
                    "description": "Maximum allowed outgoing edges per node.",
                    "minimum": 1,
                    "type": "integer"
                  },
                  "severity": {
                    "description": "Severity assigned to emitted issues.",
                    "enum": [
                      "error",
                      "warning",
                      "info"
                    ],
                    "type": "string"
                  },
                  "suppression_selectors": {
                    "description": "Selectors that suppress matching issues.",
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "no-disconnected-nodes": {
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "description": "Enable or disable this rule.",
                    "type": "boolean"
                  },
                  "severity": {
                    "description": "Severity assigned to emitted issues.",
                    "enum": [
                      "error",
                      "warning",
                      "info"
                    ],
                    "type": "string"
                  },
                  "suppression_selectors": {
                    "description": "Selectors that suppress matching issues.",
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "no-duplicate-node-ids": {
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "description": "Enable or disable this rule.",
                    "type": "boolean"
                  },
                  "severity": {
                    "description": "Severity assigned to emitted issues.",
                    "enum": [
                      "error",
                      "warning",
                      "info"
                    ],
                    "type": "string"
                  },
                  "suppression_selectors": {
                    "description": "Selectors that suppress matching issues.",
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              }
            },
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "rules": {
                "additionalProperties": false,
                "properties": {
                  "max-fanout": {
                    "additionalProperties": false,
                    "properties": {
                      "enabled": {
                        "description": "Enable or disable this rule.",
                        "type": "boolean"
                      },
                      "limit": {
                        "description": "Maximum allowed outgoing edges per node.",
                        "minimum": 1,
                        "type": "integer"
                      },
                      "severity": {
                        "description": "Severity assigned to emitted issues.",
                        "enum": [
                          "error",
                          "warning",
                          "info"
                        ],
                        "type": "string"
                      },
                      "suppression_selectors": {
                        "description": "Selectors that suppress matching issues.",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      }
                    },
                    "type": "object"
                  },
                  "no-disconnected-nodes": {
                    "additionalProperties": false,
                    "properties": {
                      "enabled": {
                        "description": "Enable or disable this rule.",
                        "type": "boolean"
                      },
                      "severity": {
                        "description": "Severity assigned to emitted issues.",
                        "enum": [
                          "error",
                          "warning",
                          "info"
                        ],
                        "type": "string"
                      },
                      "suppression_selectors": {
                        "description": "Selectors that suppress matching issues.",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      }
                    },
                    "type": "object"
                  },
                  "no-duplicate-node-ids": {
                    "additionalProperties": false,
                    "properties": {
                      "enabled": {
                        "description": "Enable or disable this rule.",
                        "type": "boolean"
                      },
                      "severity": {
                        "description": "Severity assigned to emitted issues.",
                        "enum": [
                          "error",
                          "warning",
                          "info"
                        ],
                        "type": "string"
                      },
                      "suppression_selectors": {
                        "description": "Selectors that suppress matching issues.",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      }
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              }
            },
            "required": [
              "rules"
            ],
            "type": "object"
          }
        ],
        "title": "merm8 Rule Configuration",
        "type": "object"
      },
      "RuleMetadata": {
        "properties": {
          "configurable_options": {
            "items": {
              "$ref": "#/components/schemas/RuleOption"
            },
            "type": "array"
          },
          "default_config": {
            "additionalProperties": true,
            "type": "object"
          },
          "description": {
            "type": "string"
          },
          "id": {
            "example": "max-fanout",
            "type": "string"
          },
          "severity": {
            "enum": [
              "error",
              "warning",
              "info"
            ],
            "type": "string"
          }
        },
        "required": [
          "id",
          "severity",
          "description",
          "default_config",
          "configurable_options"
        ],
        "type": "object"
      },
      "RuleOption": {
        "properties": {
          "constraints": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "type",
          "description"
        ],
        "type": "object"
      },
      "RulesResponse": {
        "properties": {
          "rules": {
            "items": {
              "$ref": "#/components/schemas/RuleMetadata"
            },
            "type": "array"
          }
        },
        "required": [
          "rules"
        ],
        "type": "object"
      },
      "SyntaxError": {
        "properties": {
          "column": {
            "description": "0-based column number where the error occurred",
            "example": 12,
            "type": "integer"
          },
          "line": {
            "description": "1-based line number where the error occurred",
            "example": 2,
            "type": "integer"
          },
          "message": {
            "description": "Error message from the Mermaid parser",
            "example": "Unexpected token '\u003e'",
            "type": "string"
          }
        },
        "required": [
          "message",
          "line",
          "column"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "contact": {
      "name": "merm8 Project",
      "url": "https://github.com/CyanAutomation/merm8"
    },
    "description": "A deterministic Mermaid static analysis engine that validates and lints Mermaid diagrams.\n\n- Accepts Mermaid code via HTTP POST\n- Validates syntax using the official Mermaid parser\n- Returns structured syntax errors if invalid\n- Runs deterministic lint rules on valid diagrams\n- Returns structured lint results with metrics",
    "license": {
      "name": "License",
      "url": "https://github.com/CyanAutomation/merm8/blob/main/LICENSE"
    },
    "title": "merm8 - Mermaid Lint API",
    "version": "1.0.0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/analyze": {
      "post": {
        "description": "Validates Mermaid code syntax and runs deterministic lint rules.\n\nMaximum request body size is 1 MiB. Oversized payloads return HTTP 413.\n\nSupports source comment suppressions such as `%% merm8-disable \u003crule-id\u003e`, `%% merm8-disable all`, and `%% merm8-disable-next-line \u003crule-id\u003e`.\n\nReturns syntax errors as semantic responses (`valid=false`) if parsing fails, or lint results if parsing succeeds.\n\nParser infrastructure failures return machine-readable API error codes:\n- `parser_subprocess_error`\n- `parser_decode_error`\n- `parser_contract_violation`\n- `parser_timeout` (HTTP 504)",
        "operationId": "analyzeCode",
        "requestBody": {
          "content": {
            "application/json": {
              "examples": {
                "simple": {
                  "summary": "Simple graph",
                  "value": {
                    "code": "graph TD\n  A[Start] --\u003e B[End]"
                  }
                },
                "syntaxError": {
                  "summary": "Invalid Mermaid syntax",
                  "value": {
                    "code": "graph TD\n  A --\u003e B --\u003e"
                  }
                },
                "withConfig": {
                  "summary": "With lint configuration",
                  "value": {
                    "code": "graph LR\n  A --\u003e B\n  B --\u003e C",
                    "config": {
                      "rules": {
                        "max-fanout": {
                          "enabled": true,
                          "limit": 2,
                          "severity": "error",
                          "suppression_selectors": [
                            "node:A"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "$ref": "#/components/schemas/AnalyzeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "sequenceDiagram": {
                    "summary": "Valid sequence diagram (lint currently unsupported)",
                    "value": {
                      "diagram_type": "sequence",
                      "issues": [],
                      "lint_supported": false,
                      "metrics": {
                        "diagram_type": "sequence",
                        "disconnected_node_count": 0,
                        "duplicate_node_count": 0,
                        "edge_count": 0,
                        "issue_counts": {
                          "by_rule": {},
                          "by_severity": {}
                        },
                        "max_fanin": 0,
                        "max_fanout": 0,
                        "node_count": 0
                      },
                      "syntax_error": null,
                      "valid": true
                    }
                  },
                  "syntaxError": {
                    "summary": "Syntax error response",
                    "value": {
                      "issues": [],
                      "lint_supported": false,
                      "syntax_error": {
                        "column": 12,
                        "line": 2,
                        "message": "Unexpected token '\u003e'"
                      },
                      "valid": false
                    }
                  },
                  "validDiagram": {
                    "summary": "Valid diagram with no issues",
                    "value": {
                      "diagram_type": "flowchart",
                      "issues": [],
                      "lint_supported": true,
                      "metrics": {
                        "diagram_type": "flowchart",
                        "direction": "TD",
                        "disconnected_node_count": 0,
                        "duplicate_node_count": 0,
                        "edge_count": 1,
                        "issue_counts": {
                          "by_rule": {},
                          "by_severity": {}
                        },
                        "max_fanin": 1,
                        "max_fanout": 1,
                        "node_count": 2
                      },
                      "syntax_error": null,
                      "valid": true
                    }
                  },
                  "withIssues": {
                    "summary": "Valid diagram with lint issues",
                    "value": {
                      "diagram_type": "flowchart",
                      "issues": [
                        {
                          "message": "Node 'D' is not connected to the graph",
                          "rule_id": "no-disconnected-nodes",
                          "severity": "error"
                        },
                        {
                          "column": 2,
                          "line": 2,
                          "message": "Node 'A' has fanout 6, exceeding limit of 5",
                          "rule_id": "max-fanout",
                          "severity": "warning"
                        }
                      ],
                      "lint_supported": true,
                      "metrics": {
                        "diagram_type": "flowchart",
                        "direction": "TD",
                        "disconnected_node_count": 1,
                        "duplicate_node_count": 0,
                        "edge_count": 2,
                        "issue_counts": {
                          "by_rule": {
                            "max-fanout": 1,
                            "no-disconnected-nodes": 1
                          },
                          "by_severity": {
                            "error": 1,
                            "warning": 1
                          }
                        },
                        "max_fanin": 1,
                        "max_fanout": 2,
                        "node_count": 4
                      },
                      "syntax_error": null,
                      "valid": true
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/AnalyzeResponse"
                }
              }
            },
            "description": "Analysis completed (valid or syntax error)"
          },
          "400": {
            "content": {
              "application/json": {
                "examples": {
                  "invalidJSON": {
                    "summary": "Invalid JSON body",
                    "value": {
                      "error": {
                        "code": "invalid_json",
                        "message": "invalid JSON body"
                      },
                      "issues": [],
                      "valid": false
                    }
                  },
                  "invalidOption": {
                    "summary": "Invalid option value",
                    "value": {
                      "error": {
                        "code": "invalid_option",
                        "message": "invalid option value for limit",
                        "path": "config.rules.max-fanout.limit"
                      },
                      "issues": [],
                      "valid": false
                    }
                  },
                  "missingCode": {
                    "summary": "Missing 'code' field",
                    "value": {
                      "error": {
                        "code": "missing_code",
                        "message": "field 'code' is required"
                      },
                      "issues": [],
                      "valid": false
                    }
                  },
                  "unknownOption": {
                    "summary": "Unknown option in rule config",
                    "value": {
                      "error": {
                        "code": "unknown_option",
                        "message": "unknown option: threshold",
                        "path": "config.rules.max-fanout.threshold",
                        "supported": [
                          "enabled",
                          "limit",
                          "severity",
                          "suppression_selectors"
                        ]
                      },
                      "issues": [],
                      "valid": false
                    }
                  },
                  "unknownRule": {
                    "summary": "Unknown rule in config",
                    "value": {
                      "error": {
                        "code": "unknown_rule",
                        "message": "unknown rule: unknown-rule",
                        "path": "config.rules.unknown-rule",
                        "supported": [
                          "max-fanout",
                          "no-disconnected-nodes",
                          "no-duplicate-node-ids"
                        ]
                      },
                      "issues": [],
                      "valid": false
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Bad request (invalid JSON, missing required field, or invalid config)"
          },
          "413": {
            "content": {
              "application/json": {
                "example": {
                  "error": {
                    "code": "request_too_large",
                    "message": "request body exceeds 1 MiB limit"
                  },
                  "issues": [],
                  "valid": false
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Request entity too large (body exceeds 1 MiB)"
          },
          "500": {
            "content": {
              "application/json": {
                "examples": {
                  "contract": {
                    "summary": "Parser contract violation",
                    "value": {
                      "error": {
                        "code": "parser_contract_violation",
                        "message": "parser response violated service contract"
                      },
                      "issues": [],
                      "valid": false
                    }
                  },
                  "decode": {
                    "summary": "Parser malformed output",
                    "value": {
                      "error": {
                        "code": "parser_decode_error",
                        "message": "parser returned malformed output"
                      },
                      "issues": [],
                      "valid": false
                    }
                  },
                  "internal": {
                    "summary": "Generic internal failure",
                    "value": {
                      "error": {
                        "code": "internal_error",
                        "message": "internal server error"
                      },
                      "issues": [],
                      "valid": false
                    }
                  },
                  "subprocess": {
                    "summary": "Parser subprocess failure",
                    "value": {
                      "error": {
                        "code": "parser_subprocess_error",
                        "message": "parser subprocess failed"
                      },
                      "issues": [],
                      "valid": false
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          },
          "504": {
            "content": {
              "application/json": {
                "example": {
                  "error": {
                    "code": "parser_timeout",
                    "message": "parser timed out while validating Mermaid code"
                  },
                  "issues": [],
                  "valid": false
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Parser timeout"
          }
        },
        "summary": "Analyze and lint a Mermaid diagram",
        "tags": [
          "Linting"
        ]
      }
    },
    "/docs": {
      "get": {
        "description": "Serve Swagger UI for interactive API exploration and testing",
        "operationId": "getDocs",
        "responses": {
          "200": {
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Swagger UI HTML page"
          }
        },
        "summary": "Interactive API documentation",
        "tags": [
          "Documentation"
        ]
      }
    },
    "/healthz": {
      "get": {
        "description": "Returns process liveness status.",
        "operationId": "getHealthz",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "ok",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Process is healthy"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "Probes"
        ]
      }
    },
    "/ready": {
      "get": {
        "description": "Returns readiness status, including parser dependency checks when available.",
        "operationId": "getReady",
        "responses": {
          "200": {
            "content": {
              "application/json": {
